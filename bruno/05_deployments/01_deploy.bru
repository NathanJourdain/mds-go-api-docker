meta {
  name: Deploy project
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/projects/{{projectId}}/deployments
  body: json
  auth: inherit
}

body:json {
  {
    "name": "v1",
    "server_id": "{{serverId}}",
    "env_override": [],
    "secret_override": {},
    "scale": {}
  }
}

script:post-response {
  bru.setEnvVar("deploymentId", res.body.id);
}
