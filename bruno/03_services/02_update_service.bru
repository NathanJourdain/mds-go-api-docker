meta {
  name: Update service
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/projects/{{projectId}}/services/{{serviceId}}
  body: json
  auth: inherit
}

body:json {
  {
    "image": "nginx:latest",
    "labels": [
      { "key": "traefik.enable", "value": "true" }
    ],
    "secrets": [],
    "networks": []
  }
}
