meta {
  name: Add service
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/projects/{{projectId}}/services
  body: json
  auth: none
}

body:json {
  {
    "name": "web",
    "image": "nginx:alpine",
    "ports": [
      { "host": "8080", "container": "80", "protocol": "tcp" }
    ],
    "env_vars": [
      { "key": "ENV", "value": "production", "is_variable": false }
    ]
  }
}

script:post-response {
  bru.setEnvVar("serviceId", res.body.id);
}
